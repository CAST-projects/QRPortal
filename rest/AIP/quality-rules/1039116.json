{
    "id": 1039116,
    "name": "Ensure setting origins when using @CrossOrigin Spring annotation",
    "href": "AIP/quality-rules/1039116",
    "critical": true,
    "severity": 20,
    "maxWeight": 7,
    "extension": {
        "name": "com.castsoftware.jeerules",
        "href": "AIP/extensions/com.castsoftware.jeerules"
    },
    "associatedValueName": "Number of violation occurrences",
    "description": "This rule reports usage of @CrossOrigin Spring annotation :\n  - without setting \"origins\" or \"originPatterns\" or \"value\"\n  - setting one of them to \"*\" or \"null\"",
    "output": "Associated to each violation, the following information is provided:\n- The number of violation occurrences\n- Bookmarks for violation occurrences found in the source code",
    "rationale": "Leaving the \"origins\" parameter unset in the @CrossOrigin annotation allows requests from any origin, increasing the risk of unauthorized access and potential exploitation of exposed API endpoints by malicious websites.",
    "reference": "CWE-346: Origin Validation Error\nhttps://cwe.mitre.org/data/definitions/346.html\n\nOWASP - HTTP Security Response Headers Cheat Sheet\nhttps://cheatsheetseries.owasp.org/cheatsheets/HTTP_Headers_Cheat_Sheet.html#access-control-allow-origin",
    "remediation": "Define a whitelist of authorized origins and pass it to @CrossOrigin.",
    "remediationSample": "@CrossOrigin(\"http://example.com\")  // FIXED",
    "sample": "@CrossOrigin  // VIOLATION",
    "total": "Number of Java artifacts",
    "alternativeName": "Avoid using @CrossOrigin Spring annotation without any restriction",
